/* Agentic Metric TUI stylesheet */

Screen {
    background: $surface;
}

#status-bar {
    height: 1;
    padding: 0 1;
    background: $boost;
}

#live-summary {
    height: 1;
    padding: 0 1;
    background: $boost;
}

#live-table {
    height: 1fr;
    min-height: 5;
}

#today-chart {
    height: 14;
    min-height: 10;
}

#trend-chart {
    height: 14;
    min-height: 10;
}

#daily-table {
    height: 1fr;
    min-height: 5;
}
